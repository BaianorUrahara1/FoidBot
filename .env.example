# FoidBot - Configuração mínima recomendada
# A maior parte da configuração é feita pelo WhatsApp com !config

# Nível de logs: error | warn | info | debug
LOG_LEVEL=info

# Pastas e arquivos de dados
BAILEYS_AUTH_FOLDER=baileys_auth
WOW_SESSIONS_DIR=baileys_wow_sessions
RATING_DATA_FILE=data/rating-state.json
RUNTIME_SETTINGS_FILE=data/runtime-settings.json

# Opcional: ajuste apenas se precisar
# COMMAND_PREFIX=!
# WOW_KEYWORD=wow
# WOW_PRIVATE_TARGET_GROUP_JID=
# RATING_GROUP_JID=
