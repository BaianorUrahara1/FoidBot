{
  "name": "foidbot",
  "version": "1.0.0",
  "description": "FoidBot: bot de WhatsApp para criar figurinhas a partir de imagens e vídeos",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:qr": "set LOG_LEVEL=error&& node src/index.js",
    "dev": "nodemon src/index.js",
    "check": "node --check src/index.js",
    "lint": "node scripts/lint.js",
    "format": "node scripts/format.js",
    "test": "node --test --test-isolation=none"
  },
  "keywords": [
    "whatsapp",
    "sticker",
    "bot"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "6.7.21",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.3.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "@whiskeysockets/baileys": {
      "libsignal": "2.0.1"
    },
    "libsignal": "2.0.1",
    "@cacheable/node-cache": "1.4.0",
    "cacheable": "1.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
